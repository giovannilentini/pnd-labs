ip addr add 192.168.100.1/24 dev eth0
ip addr add 192.168.10.1/24 dev eth1

echo "nameserver 8.8.8.8" > /etc/resolv.conf

iptables -A FORWARD -d 192.168.100.80 -p tcp --dport 80 -j ACCEPT

#iptables -A FORWARD -s 192.168.100.80 -p tcp --sport 80 -j ACCEPT
#this was also good, but it's better use -m state --state ESTABLISHED

iptables -A FORWARD -s 192.168.100.80 -m state --state ESTABLISHED,RELATED -j ACCEPT

iptables -A FORWARD eth1 -d 192.168.100.80 -j REJECT
